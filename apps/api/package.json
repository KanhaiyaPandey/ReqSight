{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "node --loader ts-node/esm src/worker.ts",
    "lint": "eslint src --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/sdk": "*",
    "bullmq": "^5.61.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ioredis": "^5.8.1",
    "mongoose": "^9.4.1"
  },
  "devDependencies": {
    "@repo/config": "*",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "5.9.2"
  }
}
